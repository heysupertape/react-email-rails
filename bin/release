#!/usr/bin/env ruby
require("open3")
require("json")
require("rubygems")
require("shellwords")
require_relative("../scripts/changelog")

USAGE = "Usage: bin/release"

abort(USAGE) unless ARGV.empty?

root = File.expand_path("..", __dir__)
Dir.chdir(root)

def run(*command, capture: false, chdir: nil)
  printable = [("cd #{Shellwords.escape(chdir)} &&" if chdir), command.shelljoin].compact.join(" ")
  puts("$ #{printable}")

  options = chdir ? { chdir: } : {}
  if capture
    stdout, stderr, status = Open3.capture3(*command, **options)
    unless status.success?
      warn(stderr) unless stderr.empty?
      abort("Command failed: #{printable}")
    end

    stdout
  else
    system(*command, exception: true, **options)
    ""
  end
end

run("git", "fetch", "--tags", "origin", "main")

release_ref = "origin/main"
version_source = run("git", "show", "#{release_ref}:lib/react_email_rails/version.rb", capture: true)
version = version_source[/VERSION = "(\d+\.\d+\.\d+)"/, 1]
abort("Could not find ReactEmailRails::VERSION at #{release_ref}") unless version

tag = "v#{version}"
package_json = JSON.parse(run("git", "show", "#{release_ref}:vite/package.json", capture: true))
package_version = package_json.fetch("version")
abort("#{release_ref} vite/package.json version #{package_version.inspect} does not match #{version.inspect}") unless package_version == version

changelog = run("git", "show", "#{release_ref}:CHANGELOG.md", capture: true)
case Changelog.notes_for(changelog, version).last
when :missing
  abort("#{release_ref} CHANGELOG.md is missing a ## #{version} section")
when :empty
  abort("#{release_ref} CHANGELOG.md section ## #{version} needs release notes before publishing")
end

if system("git", "rev-parse", "--verify", "--quiet", "refs/tags/#{tag}", out: File::NULL)
  abort("Local tag #{tag} already exists.")
end

remote_tag = run("git", "ls-remote", "--tags", "origin", "refs/tags/#{tag}", capture: true).strip
abort("Remote tag #{tag} already exists.") unless remote_tag.empty?

versions = run("git", "tag", "--list", "v[0-9]*.[0-9]*.[0-9]*", capture: true)
  .lines
  .filter_map { |line| line.strip[/\Av(\d+\.\d+\.\d+)\z/, 1] }
  .map { |tag_version| Gem::Version.new(tag_version) }
new_version = Gem::Version.new(version)
previous_version = versions.select { |tag_version| tag_version < new_version }.max
latest_version = versions.max

if latest_version && new_version <= latest_version
  abort("#{tag} must be greater than latest release v#{latest_version}")
end

release_type =
  if previous_version.nil?
    "initial"
  elsif new_version.segments[0] > previous_version.segments[0]
    "major"
  elsif new_version.segments[1] > previous_version.segments[1]
    "minor"
  elsif new_version.segments[2] > previous_version.segments[2]
    "patch"
  else
    # Unreachable given the version > latest check above; kept as a defensive guard.
    abort("Could not infer release type from v#{previous_version} to #{tag}")
  end

message = "Ready to push #{tag} (#{release_type} release). This triggers the release workflow and publishes packages."
puts(message)

print("Continue? [y/N] ")
answer = $stdin.gets&.strip&.downcase
abort("Release canceled.") unless answer == "y" || answer == "yes"

run("git", "tag", "-a", tag, release_ref, "-m", tag)
run("git", "push", "origin", tag)

puts("Pushed #{tag}. Watch the Release workflow in GitHub Actions.")
