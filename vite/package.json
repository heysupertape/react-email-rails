{
  "name": "react-email-rails",
  "version": "0.7.0",
  "description": "Build and send emails using React and Rails",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/heysupertape/react-email-rails#readme",
  "bugs": {
    "url": "https://github.com/heysupertape/react-email-rails/issues"
  },
  "keywords": [
    "rails",
    "react-email",
    "actionmailer",
    "vite",
    "email"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/heysupertape/react-email-rails.git",
    "directory": "vite"
  },
  "files": [
    "bin",
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js"
    },
    "./document": {
      "types": "./dist/document.d.ts",
      "import": "./dist/document.js"
    }
  },
  "types": "./dist/index.d.ts",
  "bin": {
    "react-email-rails-build": "./bin/build.mjs",
    "react-email-rails-config": "./bin/config.mjs",
    "react-email-rails-dev": "./bin/dev.mjs"
  },
  "scripts": {
    "build": "tsgo -p tsconfig.json",
    "check:version": "ruby ../scripts/check_version_sync.rb",
    "lint": "oxlint src test bin",
    "format": "oxfmt src test bin",
    "check:format": "oxfmt --check src test bin",
    "typecheck": "tsgo -p tsconfig.json --noEmit",
    "test": "vitest run",
    "sync:version": "ruby ../scripts/sync_version.rb",
    "ci": "pnpm run check:version && pnpm run check:format && pnpm build && pnpm lint && pnpm typecheck && pnpm test",
    "prepack": "pnpm run sync:version && pnpm build",
    "prepublishOnly": "pnpm run check:version"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "peerDependencies": {
    "@react-email/editor": "^1.5",
    "@react-email/render": "^2.0.0",
    "@tiptap/core": "^3",
    "@tiptap/html": "^3",
    "happy-dom": "^20.8.9",
    "marked": "^18",
    "react": "^18.0 || ^19.0",
    "vite": "^7.0.0 || ^8.0.0"
  },
  "peerDependenciesMeta": {
    "@react-email/editor": {
      "optional": true
    },
    "@tiptap/core": {
      "optional": true
    },
    "@tiptap/html": {
      "optional": true
    },
    "happy-dom": {
      "optional": true
    },
    "marked": {
      "optional": true
    }
  },
  "devDependencies": {
    "@react-email/editor": "^1.5.3",
    "@react-email/render": "^2.0.8",
    "@tiptap/core": "^3",
    "@tiptap/html": "^3",
    "@tiptap/pm": "^3",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.15",
    "@typescript/native-preview": "7.0.0-dev.20260630.1",
    "happy-dom": "^20.8.9",
    "marked": "^18.0.5",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.67.0",
    "oxlint-tsgolint": "^0.23.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
